{
  "name": "acessa-plus",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @acessa-plus/api dev",
    "dev:web": "pnpm --filter @acessa-plus/web dev",
    "build": "pnpm db:generate && turbo build",
    "test": "pnpm db:generate && turbo test",
    "typecheck": "pnpm db:generate && turbo typecheck",
    "lint": "pnpm db:generate && turbo lint",
    "db:generate": "pnpm --filter @acessa-plus/database prisma:generate",
    "db:deploy:production": "node scripts/deploy-prisma.mjs",
    "db:migrate": "pnpm --filter @acessa-plus/database prisma:migrate",
    "db:studio": "pnpm --filter @acessa-plus/database prisma:studio"
  },
  "dependencies": {
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
